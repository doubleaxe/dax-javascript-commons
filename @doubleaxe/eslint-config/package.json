{
  "name": "@doubleaxe/eslint-config",
  "version": "2.0.6",
  "description": "Preferred eslint config for my projects.",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config"
  ],
  "author": "Alexey Usov (dax@xdax.ru, https://github.com/doubleaxe)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/doubleaxe/dax-javascript-commons"
  },
  "homepage": "https://github.com/doubleaxe/dax-javascript-commons/tree/main/%40doubleaxe/eslint-config",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "files": [
    "dist",
    "types"
  ],
  "main": "./dist/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./es": {
      "types": "./types/es.d.ts",
      "default": "./dist/es.js"
    },
    "./ts": {
      "types": "./types/ts.d.ts",
      "default": "./dist/ts.js"
    },
    "./react-es": {
      "types": "./types/react-es.d.ts",
      "default": "./dist/react-es.js"
    },
    "./react-ts": {
      "types": "./types/react-ts.d.ts",
      "default": "./dist/react-ts.js"
    },
    "./vue-es": {
      "types": "./types/vue-es.d.ts",
      "default": "./dist/vue-es.js"
    },
    "./vue-ts": {
      "types": "./types/vue-ts.d.ts",
      "default": "./dist/vue-ts.js"
    }
  },
  "scripts": {
    "lint": "eslint --fix .",
    "format": "prettier --write .",
    "check": "tsc --noEmit",
    "clean": "rimraf ./types ./dist",
    "build": "tsc",
    "watch": "tsc --watch",
    "clean-build": "run-s clean build",
    "clean-watch": "run-s clean watch",
    "prepack": "run-s clean-build",
    "pack": "pnpm pack --pack-destination ../../dist"
  },
  "dependencies": {
    "@eslint/js": "^9.35.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.4.0"
  },
  "peerDependencies": {
    "eslint": "9.x",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "0.x",
    "eslint-plugin-vue": "^10.8.0",
    "typescript-eslint": "^8.58.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-react-refresh": {
      "optional": true
    },
    "eslint-plugin-vue": {
      "optional": true
    },
    "vue-eslint-parser": {
      "optional": true
    },
    "typescript-eslint": {
      "optional": true
    }
  },
  "devDependencies": {
    "@doubleaxe/typescript-config": "workspace:^",
    "@types/eslint-plugin-security": "^3.0.1",
    "eslint": "catalog:",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-vue": "^10.8.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "catalog:",
    "typescript-eslint": "^8.58.1",
    "vue-eslint-parser": "^10.4.0"
  }
}
