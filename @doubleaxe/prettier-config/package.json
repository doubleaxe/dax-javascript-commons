{
  "name": "@doubleaxe/prettier-config",
  "version": "1.0.5",
  "description": "Preferred prettier config for my projects.",
  "keywords": [
    "prettier"
  ],
  "author": "Alexey Usov (dax@xdax.ru, https://github.com/doubleaxe)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/doubleaxe/dax-javascript-commons"
  },
  "homepage": "https://github.com/doubleaxe/dax-javascript-commons/tree/main/%40doubleaxe/prettier-config",
  "main": "index.js",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "lint": "eslint --fix .",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "pack": "pnpm pack --pack-destination ../../dist"
  },
  "peerDependencies": {
